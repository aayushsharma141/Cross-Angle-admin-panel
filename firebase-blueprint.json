{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "viewer"],
          "description": "The user's role in the system."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post in the CMS.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "status", "authorId", "createdAt", "updatedAt"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "A portfolio project in the CMS.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "clientName": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "description", "status", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A CRM lead.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "proposal", "won", "lost"] },
        "value": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "createdAt", "updatedAt"]
    },
    "Estimate": {
      "title": "Estimate",
      "description": "A project estimate.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string" },
        "clientName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            },
            "required": ["description", "quantity", "price"]
          }
        },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "totalAmount", "items", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/blogs/{blogId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Stores blog posts."
    },
    "/portfolio/{portfolioId}": {
      "schema": { "$ref": "#/entities/PortfolioItem" },
      "description": "Stores portfolio items."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Stores CRM leads."
    },
    "/estimates/{estimateId}": {
      "schema": { "$ref": "#/entities/Estimate" },
      "description": "Stores project estimates."
    }
  }
}
